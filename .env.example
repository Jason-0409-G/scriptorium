# research-to-paper — API credentials (ALL OPTIONAL)
#
# Copy this file to ONE of these locations and fill in what you have:
#   - ./.env                                 (in your working / manuscript folder)
#   - ~/.config/research-to-paper/keys.env
#   - or point  $RESEARCH_TO_PAPER_ENV  at any path
# Your real shell environment variables always take precedence over this file.
#
# Everything works WITHOUT any of these — they only raise rate limits or join a
# faster "polite pool". NEVER commit your filled-in copy (.env / *.env are gitignored).

# --- Literature & general APIs (curate / search_papers.py) ---

# Your email — puts CrossRef, OpenAlex and NCBI requests in their faster "polite pool".
# No signup; just an email. Recommended.
CROSSREF_MAILTO=you@example.com
NCBI_EMAIL=you@example.com

# NCBI E-utilities API key — raises every NCBI database (PubMed, PMC, protein, nucleotide,
# gene, taxonomy, SRA, assembly, structure, ...) from 3 to 10 requests/sec.
# https://www.ncbi.nlm.nih.gov/account/  (Settings -> API Key Management)
NCBI_API_KEY=

# Semantic Scholar API key — higher, more reliable rate limit.
# https://www.semanticscholar.org/product/api
S2_API_KEY=

# OpenAlex API key — optional; a mailto (above) already gets you the polite pool.
# https://openalex.org/
OPENALEX_API_KEY=

# --- Reference manager: direct import (curate / push_zotero.py) ---

# Zotero Web API — lets curate push verified references STRAIGHT into your Zotero library
# (one collection per category) instead of writing an import file. Needs a key with write access.
# Key:    https://www.zotero.org/settings/keys
# userID: same page (a number). Use ZOTERO_GROUP_ID instead for a shared group library.
ZOTERO_API_KEY=
ZOTERO_USER_ID=
# ZOTERO_GROUP_ID=

# Note: EndNote exposes no public item-creation API, so there is no direct push for it —
# curate writes library.ris, which EndNote imports natively (File > Import).

